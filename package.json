{
  "name": "ai-chat-rr",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "cf-typegen": "wrangler types",
    "db:generate": "bash ./drizzle-migration",
    "db:migrate": "wrangler d1 migrations apply --local DB",
    "db:migrate-production": "dotenv -- drizzle-kit migrate --config ./src/db/d1/d1.drizzle.config.ts",
    "deploy": "pnpm run build && wrangler deploy",
    "preview": "pnpm run build && vite preview",
    "cloudflare:gen": "pnpm run cf-typegen && prettier --write worker-configuration.d.ts",
    "typecheck": "pnpm run cloudflare:gen && tsc -b",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@hookform/resolvers": "^5.2.2",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/rehype": "^3.23.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-start": "^1.166.11",
    "@tanstack/router-core": "1.167.0",
    "ai": "^6.0.141",
    "arctic": "^3.7.0",
    "aws4fetch": "^1.0.20",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "~0.45.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "immer": "^10.2.0",
    "isbot": "^5.1.36",
    "lucia": "^3.2.2",
    "lucide-react": "^0.513.0",
    "markdown-to-jsx": "^9.7.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-use-websocket": "^4.13.0",
    "react-virtuoso": "^4.18.3",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuidv7": "^1.1.0",
    "valibot": "^1.2.0",
    "vite-plugin-babel": "^1.5.1",
