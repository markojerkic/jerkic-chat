{
  "extends": "./tsconfig.json",
  "include": ["src/**/*", "database/**/*", "worker-configuration.d.ts"],
  "exclude": ["src/old_routes/**/*"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "esnext"],
    "types": ["node", "vite/client"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "rootDirs": ["."],
    "paths": {
      "~/database/*": ["./database/*"],
      "~/*": ["./src/*"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
